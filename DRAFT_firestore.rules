rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email.endsWith('@example.com')); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'pmconsultancy2024@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // Relational Helpers
    function isBookingParticipant(b) {
      return isSignedIn() && (request.auth.uid == b.tenantId || request.auth.uid == b.ownerId);
    }

    // --- Phase 4: Validation Blueprints ---

    function isValidUser(data) {
      let required = ['uid', 'email', 'role', 'displayName', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 15 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'owner', 'tenant'] &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidProperty(data) {
      let required = ['ownerId', 'title', 'price', 'type', 'isAvailable', 'status', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 30 &&
             data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.type in ['room', 'pg', 'flat', 'studio', 'house'] &&
             data.status in ['active', 'inactive'] &&
             data.isAvailable is bool &&
             data.createdAt is timestamp;
    }

    function isValidBooking(data) {
      let required = ['propertyId', 'tenantId', 'ownerId', 'status', 'amount', 'createdAt', 'startDate', 'endDate'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 40 &&
             isValidId(data.propertyId) &&
             isValidId(data.tenantId) &&
             isValidId(data.ownerId) &&
             data.tenantId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'cancelled', 'completed'] &&
             data.amount is number &&
             data.startDate is string &&
             data.endDate is string &&
             (data.createdAt is timestamp || data.createdAt is number) &&
             (!data.has('paid') || data.paid is bool) &&
             (!data.has('paymentMethod') || data.paymentMethod is string) &&
             (!data.has('transactionId') || data.transactionId is string) &&
             (!data.has('paymentDate') || (data.paymentDate is timestamp || data.paymentDate is number)) &&
             (!data.has('updatedAt') || (data.updatedAt is timestamp || data.updatedAt is number));
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phone', 'upiId', 'bio', 'photoURL', 'updatedAt']) &&
                    (!incoming().has('updatedAt') || incoming().updatedAt == request.time);
      allow delete: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProperty(incoming()) && isValidId(propertyId);
      allow update: if isSignedIn() && (isOwner(existing().ownerId) || isAdmin()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location', 'address', 'price', 'type', 'amenities', 'images', 'isAvailable', 'status', 'updatedAt', 'ownerUpiId']) &&
                    (!incoming().has('updatedAt') || incoming().updatedAt == request.time);
      allow delete: if isAdmin() || isOwner(existing().ownerId);
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isBookingParticipant(resource.data) || isAdmin());
      allow list: if isSignedIn() && (isBookingParticipant(resource.data) || isAdmin());
      allow create: if isSignedIn() && isValidBooking(incoming()) && 
                    exists(/databases/$(database)/documents/properties/$(incoming().propertyId));
      allow update: if isSignedIn() && (isBookingParticipant(existing()) || isAdmin()) &&
                    isValidBooking(incoming()) && (
                      // Tenant Action: Pay/Cancel
                      (request.auth.uid == existing().tenantId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paid', 'paymentMethod', 'transactionId', 'paymentDate', 'updatedAt'])) ||
                      // Owner Action: Confirm/Cancel
                      (request.auth.uid == existing().ownerId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && incoming().participants.size() == 2 && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && (request.auth.uid in existing().participants) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'typing']);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) &&
                    incoming().senderId == request.auth.uid;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
