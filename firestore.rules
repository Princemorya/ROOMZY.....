rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Softened for development to prevent blocking users like renter1@gmail.com
    function isVerified() { 
      return true; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'pmconsultancy2024@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isBookingParticipant(b) {
      return isSignedIn() && (request.auth.uid == b.tenantId || request.auth.uid == b.ownerId);
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      let required = ['uid', 'email', 'role', 'displayName', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 25 &&
             data.role in ['admin', 'owner', 'tenant'] &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidProperty(data) {
      let required = ['ownerId', 'title', 'price', 'type', 'isAvailable', 'status', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 50 &&
             data.title is string && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.type in ['room', 'pg', 'flat', 'studio', 'house'] &&
             data.status in ['active', 'inactive'] &&
             data.isAvailable is bool &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidBooking(data) {
      let required = ['propertyId', 'tenantId', 'ownerId', 'status', 'amount', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 60 &&
             data.status in ['pending', 'confirmed', 'cancelled', 'completed'] &&
             data.amount is number &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidReview(data) {
      let required = ['propertyId', 'tenantId', 'rating', 'comment', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 15 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) &&
                    incoming().uid == request.auth.uid && 
                    (incoming().get('email', '') == '' || incoming().email == request.auth.token.get('email', ''));
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && 
                    (
                      isAdmin() ||
                      (isOwner(userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly([
                         'displayName', 'phone', 'upiId', 'bio', 'photoURL', 
                         'governmentIdUrl', 'verificationStatus', 'updatedAt'
                       ]) &&
                       // Owner can only move to 'pending' or keep current status
                       (
                         incoming().get('verificationStatus', 'unverified') == existing().get('verificationStatus', 'unverified') || 
                         (incoming().get('verificationStatus', 'unverified') == 'pending' && 
                          existing().get('verificationStatus', 'unverified') in ['unverified', 'rejected'])
                       )
                      )
                    ) &&
                    (!incoming().has('updatedAt') || incoming().updatedAt == request.time || incoming().updatedAt is number);
      allow delete: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProperty(incoming()) && isValidId(propertyId) &&
                    incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(existing().ownerId) || isAdmin()) &&
                    (
                      isAdmin() ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location', 'address', 'price', 'type', 'amenities', 'images', 'isAvailable', 'status', 'updatedAt', 'ownerUpiId', 'ownerName', 'ownerPhoto'])
                    ) &&
                    (!incoming().has('updatedAt') || incoming().updatedAt == request.time || incoming().updatedAt is number);
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().ownerId));
    }

    match /bookings/{bookingId} {
      allow get, list: if isSignedIn() && (isBookingParticipant(resource.data) || isAdmin());
      allow create: if isSignedIn() && isValidBooking(incoming()) && 
                    incoming().tenantId == request.auth.uid;
      allow update: if isSignedIn() && (isBookingParticipant(existing()) || isAdmin()) &&
                    (
                      (request.auth.uid == existing().tenantId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paid', 'paymentMethod', 'transactionId', 'paymentDate', 'updatedAt', 'ownerUpiId'])) ||
                      (request.auth.uid == existing().ownerId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'ownerUpiId', 'paid', 'paymentDate', 'paymentMethod', 'transactionId'])) ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && isVerified() && incoming().participants.size() == 2 && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && (request.auth.uid in existing().participants) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'typing']);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
      allow create: if isSignedIn() && isVerified() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) &&
                    incoming().senderId == request.auth.uid;
    }

    match /properties/{propertyId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming()) && 
                    incoming().tenantId == request.auth.uid &&
                    incoming().propertyId == propertyId;
      allow update: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin()) &&
                    isValidReview(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'rating', 'updatedAt']);
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().tenantId));
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
